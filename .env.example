# ── Convex ────────────────────────────────────────────────────────
# These are set automatically by `npx convex dev`
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=

# ── Agora (set in Convex dashboard or via `npx convex env set`) ──
# App ID from Agora Console → Project Management
AGORA_APP_ID=
# App Certificate (enable in Agora Console → Project → Security)
# Optional — not needed if the project uses "Testing mode"
AGORA_APP_CERTIFICATE=
# Customer Key + Secret from Agora Console → RESTful API
AGORA_CUSTOMER_KEY=
AGORA_CUSTOMER_SECRET=
# Pipeline ID from Agent Studio → Agents → Embed Agent
# This bundles your pre-configured ASR, LLM, and TTS settings
AGORA_PIPELINE_ID=
# Optional: paste a temporary token from Agora Console for testing
AGORA_TEMP_TOKEN=

# ── OpenRouter (for post-call transcript classification) ─────────
# API key from https://openrouter.ai/keys
# When omitted, the keyword classifier is used as a fallback.
OPENROUTER_API_KEY=

# ── SMS API PH (for customer ticket acknowledgement SMS) ─────────
# API key from https://smsapiph.netlify.app
# When omitted, SMS notifications are silently skipped.
SMSAPI_KEY=
